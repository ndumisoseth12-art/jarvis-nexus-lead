{
  "cleanUrls": true,
  "trailingSlash": false,
  "rewrites": [
    { "source": "/leads",          "destination": "/leads.html" },
    { "source": "/churn",          "destination": "/churn.html" },
    { "source": "/recovery",       "destination": "/recovery.html" },
    { "source": "/support",        "destination": "/support.html" },
    { "source": "/lifetime",       "destination": "/lifetime.html" },
    { "source": "/reviews",        "destination": "/reviews.html" },
    { "source": "/airbnb",         "destination": "/airbnb.html" },
    { "source": "/noshow",         "destination": "/noshow.html" },
    { "source": "/reactivation",   "destination": "/reactivation.html" },
    { "source": "/reputation",     "destination": "/reputation.html" },
    { "source": "/referral",       "destination": "/referral.html" },
    { "source": "/thank-you",      "destination": "/thank-you.html" },
    { "source": "/dashboard",      "destination": "/dashboard.html" },
    { "source": "/review-request", "destination": "/review-request.html" },
    { "source": "/onboarding",     "destination": "/onboarding.html" },
    { "source": "/proposal",       "destination": "/proposal.html" },

    { "source": "/api/router",            "destination": "https://n8n-production-71d9.up.railway.app/webhook/master-router" },
    { "source": "/api/payfast-subscribe", "destination": "https://n8n-production-71d9.up.railway.app/webhook/payfast-subscribe" },
    { "source": "/api/webhook/:path*",    "destination": "https://n8n-production-71d9.up.railway.app/webhook/:path*" }
  ],
  "headers": [
    {
      "source": "/((?!api/).*)",
      "headers": [
        {
          "key": "Content-Security-Policy",
          "value": "default-src 'self'; script-src 'self' 'unsafe-inline'; style-src 'self' 'unsafe-inline' https://fonts.googleapis.com; font-src 'self' https://fonts.gstatic.com data:; img-src 'self' data: https:; connect-src 'self'; frame-ancestors 'none'; base-uri 'self'; form-action 'self'; upgrade-insecure-requests"
        },
        { "key": "X-Content-Type-Options",      "value": "nosniff" },
        { "key": "Referrer-Policy",             "value": "strict-origin-when-cross-origin" },
        { "key": "Permissions-Policy",          "value": "camera=(), microphone=(), geolocation=(), interest-cohort=()" },
        { "key": "Strict-Transport-Security",   "value": "max-age=63072000; includeSubDomains; preload" }
      ]
    }
  ]
}
