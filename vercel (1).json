{
  "cleanUrls": true,
  "trailingSlash": false,
  "rewrites": [
    { "source": "/leads", "destination": "/leads.html" },
    { "source": "/reviews", "destination": "/reviews.html" },
    { "source": "/support", "destination": "/support.html" },
    { "source": "/airbnb", "destination": "/airbnb.html" }
  ],
  "routes": [
    { "src": "/leads", "dest": "/leads.html" },
    { "src": "/reviews", "dest": "/reviews.html" },
    { "src": "/support", "dest": "/support.html" },
    { "src": "/airbnb", "dest": "/airbnb.html" },
    { "src": "/(.*)", "dest": "/$1" }
  ]
}
